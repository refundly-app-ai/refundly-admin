# ============================================================
# Refundly Admin Panel — Environment Variables
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no repositório
# ============================================================

# URL pública do app (localhost para dev, domínio real para prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
# Supabase → Settings → API → Project URL
SUPABASE_URL=

# Supabase → Settings → API → service_role key
# ATENÇÃO: nunca usar com prefixo NEXT_PUBLIC_ — server only
SUPABASE_SERVICE_ROLE_KEY=

# ── Sessão e criptografia ────────────────────────────────────
# Chave aleatória de 32+ bytes para assinar cookies de sessão
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Chave AES-256 para criptografar o totp_secret em repouso
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOTP_ENCRYPTION_KEY=

# ── Upstash Redis (rate limiting) ────────────────────────────
# Upstash → Redis → seu banco → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── SMTP (emails de convite e reset) ────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=admin@refundly.com

# ── Segurança opcional ───────────────────────────────────────
# IPs permitidos para acessar o painel, separados por vírgula
# Deixe vazio para permitir qualquer IP
ALLOWED_ADMIN_IPS=
